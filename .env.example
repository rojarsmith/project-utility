# Copy this file to .env and fill in your own values. .env is git-ignored.

# GitHub Personal Access Token with "repo" scope.
# Required to list private repositories via the authenticated /user/repos endpoint.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Only used when GITHUB_TOKEN is empty: lists public repositories of this user.
GITHUB_USERNAME=

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OUTPUT_FILE=github-repository.txt
GITHUB_PER_PAGE=100

# Which repos GITHUB_TOKEN's account can see, passed as GitHub's "affiliation" param.
# - owner: only repos owned by this account (excludes repos you were only invited to
#          as a collaborator or that belong to an organization you are a member of)
# - collaborator: repos you were added to as a collaborator
# - organization_member: repos of organizations you belong to
# Comma-combine multiple values, e.g. owner,organization_member. Default: owner
GITHUB_AFFILIATION=owner

# --- github-integrity.py ---

# Repository list produced by github-repository.py, used as the source of truth to check against.
GITHUB_REPOSITORY_LIST_FILE=github-repository.txt

# Where the integrity report is written.
GITHUB_INTEGRITY_REPORT_FILE=github-integrity.txt

# Directory to scan for local clones, one folder per repo name. Default: ..
# (the parent directory, matching where git-clone-alot.bat clones repos to).
GITHUB_INTEGRITY_PARENT_DIR=..
