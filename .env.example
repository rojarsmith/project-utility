# Copy this file to .env and fill in your own values. .env is git-ignored.

# GitHub Personal Access Token with "repo" scope.
# Required to list private repositories via the authenticated /user/repos endpoint.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Only used when GITHUB_TOKEN is empty: lists public repositories of this user.
GITHUB_USERNAME=

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OUTPUT_FILE=github-repository.txt
GITHUB_PER_PAGE=100

# Which repos GITHUB_TOKEN's account can see, passed as GitHub's "affiliation" param.
# - owner: only repos owned by this account (excludes repos you were only invited to
#          as a collaborator or that belong to an organization you are a member of)
# - collaborator: repos you were added to as a collaborator
# - organization_member: repos of organizations you belong to
# Comma-combine multiple values, e.g. owner,organization_member. Default: owner
GITHUB_AFFILIATION=owner

# --- github-integrity.py / github-clone.py / github-pull.py ---

# Repository list produced by github-repository.py, used as the source of truth
# to check against (github-integrity.py), to clone from (github-clone.py), and
# to pull updates for (github-pull.py).
GITHUB_REPOSITORY_LIST_FILE=github-repository.txt

# --- github-integrity.py ---

# Where the integrity report is written.
GITHUB_INTEGRITY_REPORT_FILE=github-integrity.txt

# Directory to scan for local clones, one folder per repo name. Default: ..
# (the parent directory, matching where git-clone-alot.bat clones repos to).
GITHUB_INTEGRITY_PARENT_DIR=..

# --- github-clone.py ---

# Directory to clone missing repositories into, one folder per repo name.
# Default: .. (the parent directory, matching where git-clone-alot.bat clones repos to).
GITHUB_CLONE_TARGET_DIR=..

# --- github-pull.py ---

# Directory containing the local repo folders to pull updates into. Default: ..
GITHUB_PULL_TARGET_DIR=..

# Where the pull report is written.
GITHUB_PULL_REPORT_FILE=github-pull.txt

# --- cloudflare-dns.py ---

# Preferred: a scoped API Token (Zone:DNS:Edit permission on the target zone).
# Create one at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Legacy alternative to CLOUDFLARE_API_TOKEN: the account-wide Global API Key,
# used together with the account email. Only needed if you are not using a token.
CLOUDFLARE_API_KEY=
CLOUDFLARE_API_EMAIL=

CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4

# Either set the zone ID directly, or the zone's domain name to have it looked up.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ZONE_NAME=example.com

# The DNS record to create/update, and the value it should be set to.
CLOUDFLARE_RECORD_NAME=sub.example.com
CLOUDFLARE_RECORD_TYPE=A
CLOUDFLARE_RECORD_CONTENT=203.0.113.10
CLOUDFLARE_RECORD_TTL=1
CLOUDFLARE_RECORD_PROXIED=false
